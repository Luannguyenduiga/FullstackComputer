@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tin Công Nghệ - Fullstack Computer</title>
    <link rel="stylesheet" href="/assets/css/grid.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="/assets/css/nav.css">
    <link rel="stylesheet" href="/assets/css/footer.css">
    <link rel="stylesheet" href="/assets/css/technews.css">
    <link rel="stylesheet" href="/assets/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Lexend', sans-serif;
            background-color: #f4f7f6;
            color: #333;
        }

        .news-container {
            padding: 40px 0;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-left: 5px solid #b21f1f;
            padding-left: 15px;
        }

        /* Top Feature Layout */
        .featured-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            margin-bottom: 40px;
        }

        .main-feature {
            position: relative;
            border-radius: 15px;
            overflow: hidden;
            height: 450px;
        }

        .main-feature img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.5s;
        }

        .feature-info {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 30px;
            background: linear-gradient(transparent, rgba(0, 0, 0, 0.9));
            color: white;
        }

        .tag-tech {
            background: #b21f1f;
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        .side-features {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .side-item {
            display: flex;
            gap: 15px;
            background: white;
            padding: 10px;
            border-radius: 12px;
            height: 100%;
            transition: 0.3s;
        }

        .side-item:hover {
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        .side-item img {
            width: 100px;
            height: 100px;
            border-radius: 8px;
            object-fit: cover;
        }

        .side-item h4 {
            font-size: 0.95rem;
            line-height: 1.4;
        }

        /* News List Grid */
        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
        }

        .news-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            transition: 0.3s;
            border: 1px solid #eee;
        }

        .news-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }

        .news-card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
        }

        .news-content {
            padding: 20px;
        }

        .news-content .date {
            font-size: 0.8rem;
            color: #888;
            margin-bottom: 10px;
            display: block;
        }

        .news-content h3 {
            font-size: 1.1rem;
            margin-bottom: 10px;
            line-height: 1.5;
            color: #1a2a6c;
        }

        .sidebar-trending {
            background: white;
            padding: 25px;
            border-radius: 15px;
        }

        .trending-list {
            list-style: none;
            margin-top: 20px;
        }

        .trending-list li {
            padding: 15px 0;
            border-bottom: 1px solid #eee;
            display: flex;
            gap: 10px;
        }

        .rank {
            font-size: 1.5rem;
            font-weight: 800;
            color: #ddd;
        }
    </style>
    <link rel="stylesheet" href="/assets/css/responsive.css">
</head>

<body>
    <div class="news-top-bar">
        <div class="container flex-between">
            <div class="current-date">
                <i class="fa-regular fa-calendar-days"></i> <span id="today-date">Thứ Năm, 09 Tháng 4, 2026</span>
            </div>
            <div class="top-links">
                <a href="#">Giới thiệu</a>
                <a href="#">Liên hệ quảng cáo</a>
                <a href="#">RSS <i class="fa-solid fa-rss"></i></a>
            </div>
        </div>
    </div>

    <header class="news-nav-wrapper">
        <nav class="container flex-between">
            <div class="news-logo">
                <a href="/Home/Index">FULLSTACK<span>NEWS</span></a>
            </div>

            <ul class="news-menu">
                <li class="active"><a href="#">Trang chủ</a></li>
                <li><a href="#">Trí tuệ nhân tạo (AI)</a></li>
                <li><a href="#">Điện thoại</a></li>
                <li><a href="#">Máy tính & Laptop</a></li>
                <li><a href="#">Phần cứng</a></li>
                <li><a href="#">Thủ thuật</a></li>
                <li><a href="#">E-Sports</a></li>
            </ul>

            <div class="news-actions">
                <button class="search-btn" onclick="openSearch()"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
            <dialog id="searchDialog" class="search-modal">
                <div class="container search-wrapper">
                    <div class="search-field">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="searchInput">
                    </div>
                    <button class="btn-close-dialog" onclick="closeSearch()">
                        <i class="fa-solid fa-xmark"></i> Đóng
                    </button>
                    <button class="btn-close-dialog" onclick="closeSearch()">
                        <i class="fa-solid fa-magnifying-glass"></i> Tìm kiếm
                    </button>
                </div>
            </dialog>
        </nav>

    </header>

    <div class="container news-container">
        <div class="featured-grid">
            <div class="main-feature">
                <img src="https://images.unsplash.com/photo-1707343843437-caacff5cfa74?q=80&w=1200&auto=format&fit=crop"
                    alt="AI Feature">
                <div class="feature-info">
                    <span class="tag-tech">Trí tuệ nhân tạo</span>
                    <h2 style="margin: 15px 0;">Slogan mới của Fullstack Computer: Làm chủ AI để dẫn đầu tương lai công
                        nghệ 2026</h2>
                    <p>Khám phá cách AI đang thay đổi cách chúng ta build PC và tối ưu hóa hiệu suất làm việc...</p>
                </div>
            </div>

            <div class="side-features">
                <div class="side-item">
                    <img src="https://images.unsplash.com/photo-1591799264318-7e6ef8ddb7ea?q=80&w=200&auto=format&fit=crop"
                        alt="VGA">
                    <div>
                        <span style="color: #b21f1f; font-size: 0.7rem; font-weight: bold;">PHẦN CỨNG</span>
                        <h4>Lộ diện RTX 5090: Sức mạnh hủy diệt mọi tựa game 4K</h4>
                    </div>
                </div>
                <div class="side-item">
                    <img src="https://images.unsplash.com/photo-1531297484001-80022131f5a1?q=80&w=200&auto=format&fit=crop"
                        alt="Laptop">
                    <div>
                        <span style="color: #b21f1f; font-size: 0.7rem; font-weight: bold;">LAPTOP</span>
                        <h4>Đánh giá MacBook Air M4: Có thực sự đáng nâng cấp?</h4>
                    </div>
                </div>
                <div class="side-item">
                    <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=200&auto=format&fit=crop"
                        alt="Security">
                    <div>
                        <span style="color: #b21f1f; font-size: 0.7rem; font-weight: bold;">AN NINH MẠNG</span>
                        <h4>Cảnh báo lỗ hổng bảo mật mới trên các dòng Router phổ biến</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-8">
                <div class="section-header">
                    <h2>MỚI CẬP NHẬT</h2>
                    <a href="#" style="color: #1a2a6c; text-decoration: none;">Xem tất cả <i
                            class="fa-solid fa-arrow-right"></i></a>
                </div>

                <div class="news-grid">
                    <div class="news-card">
                        <img src="https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=400&auto=format&fit=crop"
                            alt="News 1">
                        <div class="news-content">
                            <span class="date">09 Tháng 4, 2026</span>
                            <h3>Top 5 cấu hình PC Gaming đáng mua nhất tầm giá 20 triệu</h3>
                            <p style="font-size: 0.9rem; color: #666;">Dành cho sinh viên cần một chiếc máy vừa học vừa
                                chơi mượt mà...</p>
                        </div>
                    </div>
                    <div class="news-card">
                        <img src="https://images.unsplash.com/photo-1485827404703-89b55fcc595e?q=80&w=400&auto=format&fit=crop"
                            alt="News 2">
                        <div class="news-content">
                            <span class="date">08 Tháng 4, 2026</span>
                            <h3>ChatGPT-5 chuẩn bị ra mắt: Những tính năng gây sốc</h3>
                            <p style="font-size: 0.9rem; color: #666;">Cùng Fullstack Computer điểm qua những thay đổi
                                lớn nhất...</p>
                        </div>
                    </div>
                    <div class="news-card">
                        <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=400&auto=format&fit=crop"
                            alt="News 3">
                        <div class="news-content">
                            <span class="date">07 Tháng 4, 2026</span>
                            <h3>Intel Core Ultra: Kỷ nguyên mới của Laptop tích hợp AI</h3>
                            <p style="font-size: 0.9rem; color: #666;">Chip xử lý mới giúp kéo dài thời lượng pin lên
                                đến 20 giờ...</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-4">
                <div class="sidebar-trending">
                    <h3 style="border-bottom: 2px solid #1a2a6c; padding-bottom: 10px;">XEM NHIỀU NHẤT</h3>
                    <ul class="trending-list">
                        <li>
                            <span class="rank">01</span>
                            <p>Cách tối ưu Windows 11 để chơi game mượt hơn 30%</p>
                        </li>
                        <li>
                            <span class="rank">02</span>
                            <p>Fullstack Computer khai trương showroom thứ 15 tại TP.HCM</p>
                        </li>
                        <li>
                            <span class="rank">03</span>
                            <p>iPhone 17 Pro Max sẽ có màu sắc mới cực độc lạ?</p>
                        </li>
                    </ul>
                </div>

                <div style="margin-top: 30px; border-radius: 15px; overflow: hidden;">
                    <img src="https://images.unsplash.com/photo-1603302576837-37561b2e2302?q=80&w=400&auto=format&fit=crop"
                        alt="Banner AD" style="width: 100%;">
                </div>
            </div>
        </div>
    </div>

    <footer class="footer">
    </footer>
    <script>
        const modal = document.getElementById('searchDialog');
        const searchInput = document.getElementById('searchInput'); // Trỏ đúng vào ô input

        function openSearch() {
            modal.showModal();
            // Đợi animation trượt xuống rồi mới focus vào ô nhập liệu
            setTimeout(() => {
                searchInput.focus();
            }, 100);
        }

        function closeSearch() {
            modal.style.transform = 'translateY(-100%)';
            setTimeout(() => {
                modal.close();
                modal.style.transform = '';
            }, 400);
        }

        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeSearch();
        });
    </script>
</body>

</html>


