@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Về Chúng Tôi - Fullstack Computer</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1a2a6c;
            --secondary: #b21f1f;
            --gold: #fdbb2d;
            --dark: #0f172a;
            --light: #f8fafc;
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        body {
            font-family: 'Lexend', sans-serif;
            background-color: var(--light);
            color: var(--dark);
            line-height: 1.8;
        }

        /* Hero Section với hiệu ứng Parallax nhẹ */
        .about-hero {
            height: 70vh;
            background: linear-gradient(rgba(15, 23, 42, 0.7), rgba(26, 42, 108, 0.5)),
                        url('https://biztechmagazine.com/sites/biztechmagazine.com/files/styles/cdw_hero/public/articles/202406/GettyImages-2152027423.jpg?itok=_KA3McNz');
            background-size: cover;
            background-attachment: fixed;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-align: center;
            clip-path: polygon(0 0, 100% 0, 100% 90%, 0 100%);
        }

        .hero-content h1 {
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 20px;
            text-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }

        /* Story Section */
        .section-padding { padding: 100px 0; }
        
        .story-img-container {
            position: relative;
            padding: 20px;
        }

        .story-img {
            width: 100%;
            border-radius: 30px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.1);
            position: relative;
            z-index: 2;
        }

        .story-img-container::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 70%;
            height: 90%;
            background: var(--secondary);
            border-radius: 30px;
            z-index: 1;
        }

        /* Vision Cards - Glassmorphism */
        .vision-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: -50px;
        }

        .vision-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            padding: 50px 40px;
            border-radius: 24px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.3);
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
            transition: var(--transition);
        }

        .vision-card:hover {
            transform: translateY(-15px);
            background: var(--white);
            box-shadow: 0 30px 60px rgba(26, 42, 108, 0.1);
        }

        .vision-card i {
            font-size: 3.5rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 25px;
        }

        /* Stats Section */
        .stats-bar {
            background: var(--white);
            padding: 60px 0;
            border-bottom: 1px solid #eee;
        }

        .stat-item h2 {
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 0;
        }

        .stat-item p {
            color: var(--text-muted);
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 1px;
            font-size: 0.9rem;
        }

        /* Founders Section - Premium Dark Mode */
        .founders-section {
            background: var(--dark);
            color: white;
            padding: 120px 0;
            position: relative;
            overflow: hidden;
        }

        .founders-section::after {
            content: 'CORE TEAM';
            position: absolute;
            bottom: -50px;
            right: -20px;
            font-size: 15rem;
            font-weight: 900;
            color: rgba(255,255,255,0.03);
            pointer-events: none;
        }

        .quote-text {
            font-size: 1.8rem;
            font-weight: 300;
            font-style: italic;
            max-width: 900px;
            margin: 0 auto 60px;
            position: relative;
        }

        .quote-text::before {
            content: '"';
            font-size: 8rem;
            position: absolute;
            top: -40px;
            left: -30px;
            opacity: 0.2;
            color: var(--gold);
        }

        .founder-list {
            display: flex;
            justify-content: center;
            gap: 50px;
            flex-wrap: wrap;
        }

        .founder-name {
            position: relative;
            padding-bottom: 10px;
        }

        .founder-name h4 {
            font-size: 1.4rem;
            color: var(--gold);
            letter-spacing: 2px;
            margin-bottom: 5px;
        }

        .founder-name span {
            font-size: 0.8rem;
            opacity: 0.6;
            text-transform: uppercase;
        }

        .founder-name::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 30px;
            height: 2px;
            background: var(--secondary);
        }

        @@media (max-width: 768px) {
            .vision-grid { margin-top: 20px; }
            .founder-list { gap: 30px; }
        }
    </style>
    <link rel="stylesheet" href="/assets/css/responsive.css">
</head>
<body>

    <section class="about-hero">
        <div class="hero-content">
            <h1>Kiến Tạo Kỷ Nguyên AI</h1>
            <p>Fullstack Computer — Nơi công nghệ gặp gỡ khát vọng</p>
        </div>
    </section>

    <!-- Tầm nhìn & Sứ mệnh (Nổi lên trên Hero) -->
    <section class="container" style="position: relative; z-index: 10;">
        <div class="vision-grid">
            <div class="vision-card">
                <i class="fa-solid fa-eye"></i>
                <h3>Tầm Nhìn</h3>
                <p>Trở thành hệ thống bán lẻ dẫn đầu, định nghĩa lại trải nghiệm công nghệ High-end tại Việt Nam.</p>
            </div>
            <div class="vision-card">
                <i class="fa-solid fa-rocket"></i>
                <h3>Sứ Mệnh</h3>
                <p>Cung cấp hệ sinh thái phần cứng tối ưu cho xử lý AI, đồ họa và Gaming chuyên nghiệp.</p>
            </div>
            <div class="vision-card">
                <i class="fa-solid fa-gem"></i>
                <h3>Giá Trị</h3>
                <p>Tín làm gốc - Tâm làm nền - Trí làm đòn bẩy. Mỗi khách hàng là một đối tác chiến lược.</p>
            </div>
        </div>
    </section>

    <section class="section-padding">
        <div class="container">
            <div class="row align-center">
                <div class="col-6">
                    <h2 style="font-size: 2.5rem; color: var(--primary); margin-bottom: 30px;">Hành Trình Gần Một Thập Kỷ</h2>
                    <p>Khởi nguồn từ năm 2018 với niềm đam mê bất tận cho những bảng mạch và dòng code, <strong>Fullstack Computer</strong> không chỉ bán máy tính, chúng tôi bán giải pháp để bạn chinh phục những đỉnh cao mới.</p>
                    <p style="margin-top: 20px; border-left: 4px solid var(--secondary); padding-left: 20px; font-style: italic;">
                        "Chúng tôi tin rằng, công nghệ chỉ thực sự có giá trị khi nó được đặt đúng vào tay người có khát khao thay đổi thế giới."
                    </p>
                </div>
                <div class="col-6">
                    <div class="story-img-container">
                        <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="Teamwork" class="story-img">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Bar -->
    <div class="stats-bar">
        <div class="container">
            <div class="row" style="text-align: center;">
                <div class="col-3 stat-item">
                    <h2>8+</h2>
                    <p>Năm hình thành</p>
                </div>
                <div class="col-3 stat-item">
                    <h2>50K</h2>
                    <p>Khách hàng thân thiết</p>
                </div>
                <div class="col-3 stat-item">
                    <h2>15</h2>
                    <p>Trung tâm trải nghiệm</p>
                </div>
                <div class="col-3 stat-item">
                    <h2>1:1</h2>
                    <p>Chế độ bảo hành vàng</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Founders Section -->
    <section class="founders-section">
        <div class="container" style="text-align: center; position: relative; z-index: 2;">
            <p class="quote-text">
                "Công nghệ không đứng yên, và Fullstack Computer cũng vậy. Chúng tôi ở đây để đảm bảo bạn luôn có những công cụ mạnh mẽ nhất để kiến tạo tương lai."
            </p>
            
            <div class="founder-list">
                <div class="founder-name">
                    <h4>NGUYỄN THÀNH LUÂN</h4>
                    <span>Founder & CEO</span>
                </div>
                <div class="founder-name">
                    <h4>TRẦN ĐỨC HUY</h4>
                    <span>Co-Founder & CTO</span>
                </div>
                <div class="founder-name">
                    <h4>CÁI HUỲNH THANH NGHĨA</h4>
                    <span>Co-Founder & CMO</span>
                </div>
            </div>
        </div>
    </section>

</body>
</html>


