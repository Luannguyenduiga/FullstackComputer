    <script>
        function copyCode(code) {
            navigator.clipboard.writeText(code);
            // Sử dụng cái Custom Alert mà mình đã làm cho Luân ở bài trước nhé!
            if (typeof showAlert === "function") {
                showAlert('Đã sao chép mã: ' + code + '. Hãy dán vào giỏ hàng nhé!');
            } else {
                alert('Đã sao chép mã: ' + code);
            }
