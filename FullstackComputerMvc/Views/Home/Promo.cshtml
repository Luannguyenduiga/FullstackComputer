    <style>
        body {
            font-family: 'Lexend', sans-serif;
            background-color: #fcebeb;
        }

        .promo-header {
            text-align: center;
            padding: 60px 0;
            background: linear-gradient(135deg, #186ba2, #4f55be);
            color: white;
            border-radius: 0 0 50px 50px;
            margin-bottom: 50px;
        }

        .promo-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            padding-bottom: 80px;
        }

        /* Thẻ Khuyến Mãi kiểu Ticket */
        .promo-card {
            background: #fff;
            display: flex;
            border-radius: 15px;
            overflow: hidden;
            position: relative;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            transition: 0.3s;
            cursor: pointer;
        }

        .promo-card:hover {
            transform: scale(1.03);
        }

        /* Phần trái của vé */
        .promo-left {
            background: #b21f1f;
            color: white;
            padding: 20px;
            width: 100px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border-right: 2px dashed #fcebeb;
        }

        .promo-left h2 {
            font-size: 1.5rem;
            font-weight: 800;
        }

        .promo-left span {
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        /* Phần phải của vé */
        .promo-right {
            padding: 20px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .promo-right h3 {
            color: #1a2a6c;
            font-size: 1.1rem;
            margin-bottom: 10px;
        }

        .promo-right p {
            font-size: 0.85rem;
            color: #666;
            margin-bottom: 15px;
        }

        .btn-copy {
            background: #f1f2f6;
            border: 1px dashed #b21f1f;
            padding: 8px;
            border-radius: 8px;
            font-size: 0.9rem;
            text-align: center;
            font-weight: bold;
            color: #b21f1f;
            transition: 0.3s;
        }

        .promo-card:hover .btn-copy {
            background: #b21f1f;
            color: #fff;
            border-style: solid;
        }

        /* Các lỗ khuyết kiểu vé xem phim */
        .promo-card::before,
        .promo-card::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            background: #fcebeb;
            border-radius: 50%;
            left: 90px;
        }

        .promo-card::before {
            top: -10px;
        }

        .promo-card::after {
            bottom: -10px;
        }
    </style>
    <link rel="stylesheet" href="/assets/css/responsive.css">
